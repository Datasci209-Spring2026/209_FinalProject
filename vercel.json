{
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "js/**", "use": "@vercel/static" },
    { "src": "css/**", "use": "@vercel/static" },
    { "src": "data/**", "use": "@vercel/static" },
    { "src": "usability_study/js/**", "use": "@vercel/static" },
    { "src": "usability_study/data/**", "use": "@vercel/static" },
    { "src": "static/**", "use": "@vercel/static" },
    { "src": "app.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "^/$", "dest": "/index.html" },

    { "src": "^/js/(.*)", "dest": "/js/$1" },
    { "src": "^/css/(.*)", "dest": "/css/$1" },
    { "src": "^/data/(.*)", "dest": "/data/$1" },

    { "src": "^/usability_study/js/(.*)", "dest": "/usability_study/js/$1" },
    { "src": "^/usability_study/data/(.*)", "dest": "/usability_study/data/$1" },

    { "src": "^/static/(.*)", "dest": "/static/$1" },

    { "src": "^/(.*)$", "dest": "/app.py" }
  ]
}