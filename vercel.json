{
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": ""/williamprojecteda.html"
    },
    {
      "src": "/(.*)",
      "dest": "/app.py"
    }
  ]
}
