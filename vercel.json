{
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "williamprojecteda.html",
      "use": "@vercel/static"
    },
    {
      "src": "js/**",
      "use": "@vercel/static"
    },
    {
      "src": "css/**",
      "use": "@vercel/static"
    },
    {
      "src": "data/**",
      "use": "@vercel/static"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    },
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/$",
      "dest": "/williamprojecteda.html"
    },
    {
      "src": "^/(js/.*|css/.*|data/.*|static/.*)$",
      "dest": "/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/app.py"
    }
  ]
}
